---
import Layout from '../layouts/Layout.astro';

type IconName =
  | 'ti-rocket'
  | 'ti-key'
  | 'ti-layout'
  | 'ti-chart'
  | 'ti-shopping-cart'
  | 'ti-sparkles'
  | 'ti-confetti'
  | 'ti-puzzle'
  | 'ti-speakerphone'
  | 'ti-message-2-heart'
  | 'ti-envelope'
  | 'ti-writing';

type Service = { name: string; tagline: string; icon: IconName };

const services: Service[] = [
  { name: 'Custom Domain + Hosting',   tagline: 'Because "mysite.wix.com" is nobody\'s dream.', icon: 'ti-rocket' },
  { name: 'Client CMS Access',         tagline: 'Update your own content anytime — because you shouldn\'t have to call us every time you want to change your hours.', icon: 'ti-key' },
  { name: 'Page Layouts & Design',     tagline: 'Your website should work as hard as you do — look good, load fast, leave an impression.', icon: 'ti-layout' },
  { name: 'SEO & Analytics',           tagline: 'Charts that answer the question you actually had.', icon: 'ti-chart' },
  { name: 'Basic E-commerce',          tagline: 'So you can get paid while you sleep.', icon: 'ti-shopping-cart' },
  { name: 'Creative Direction',        tagline: 'Someone has to hold the vision. We brought snacks.', icon: 'ti-sparkles' },
  { name: 'Site Updates',              tagline: 'Your website shouldn\'t still be wishing people a Happy New Year in March — or a Merry Christmas in July.', icon: 'ti-confetti' },
  { name: 'Third-Party Integrations',  tagline: 'Booking, payments, phone lines, email automation — if there\'s a will, there\'s probably an app.', icon: 'ti-puzzle' },
  { name: 'Site-based Campaigns',      tagline: 'Your big moment deserves more than a link in bio.', icon: 'ti-speakerphone' },
  { name: 'Contact & Inquiry Forms',   tagline: 'Because "just DM me" is not a business strategy.', icon: 'ti-message-2-heart' },
  { name: 'Email & Newsletters',       tagline: 'People still read these. Especially yours.', icon: 'ti-envelope' },
  { name: 'Blog or Content Systems',   tagline: 'Your voice deserves a bigger stage than a Facebook post.', icon: 'ti-writing' },
];

const TEAL = '#05d7d1';
const GOLD = '#E8B84B';
---

<Layout
  title="Dream Big | RGV Web Design & Logo Services — Socially Awkward Media"
  description="Web design, logo design, branding, and more for small businesses across the Rio Grande Valley. See how Socially Awkward Media helps you look as good as the work you do."
  image="/dream-big-sky.jpg"
  wide
>
  <header class="dream-big-banner">
    <h1 class="dream-big-heading">DREAM BIG</h1>
    <p class="dream-big-subtitle">
      If you can dream it, we can probably build it<br />
      &mdash; the laws of physics are more like&hellip; guidelines.
    </p>
  </header>

  <section class="mt-14 grid auto-rows-fr grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
    {services.map((s) => (
      <article
        class="group relative overflow-hidden rounded-xl bg-white shadow-sm transition-shadow hover:shadow-md"
        style={`border: 2px solid ${TEAL};`}
      >
        {/* Gold accent bar at top */}
        <div class="h-2 w-full" style={`background-color: ${GOLD};`}></div>

        <div class="p-6">
          {/* Teal icon (Tabler-style outline, 24px viewBox, 1.6 stroke) */}
          <div style={`color: ${TEAL};`}>
            {s.icon === 'ti-rocket' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="40" height="40" aria-hidden="true">
                <path d="M4 13a8 8 0 0 1 7 7a6 6 0 0 0 3 -5a9 9 0 0 0 6 -8a3 3 0 0 0 -3 -3a9 9 0 0 0 -8 6a6 6 0 0 0 -5 3"/>
                <path d="M7 14a6 6 0 0 0 -3 6a6 6 0 0 0 6 -3"/>
                <circle cx="15" cy="9" r="1"/>
              </svg>
            )}
            {s.icon === 'ti-key' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="40" height="40" aria-hidden="true">
                <circle cx="8" cy="15" r="4"/>
                <path d="M10.85 12.15l8.15 -8.15"/>
                <path d="M16 7l3 3"/>
                <path d="M13.5 9.5l2 2"/>
              </svg>
            )}
            {s.icon === 'ti-layout' && (
              <i class="ti ti-layout" style="font-size:40px;line-height:1" aria-hidden="true"></i>
            )}
            {s.icon === 'ti-chart' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="40" height="40" aria-hidden="true">
                <line x1="4" y1="20" x2="20" y2="20"/>
                <rect x="6" y="12" width="3" height="8"/>
                <rect x="11" y="8" width="3" height="12"/>
                <rect x="16" y="4" width="3" height="16"/>
              </svg>
            )}
            {s.icon === 'ti-shopping-cart' && (
              <i class="ti ti-shopping-cart" style="font-size:40px;line-height:1" aria-hidden="true"></i>
            )}
            {s.icon === 'ti-sparkles' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="40" height="40" aria-hidden="true">
                <path d="M12 3 13.5 8 18.5 9.5 13.5 11 12 16 10.5 11 5.5 9.5 10.5 8Z"/>
                <path d="M18.5 15.5 19.5 18.5 22.5 19.5 19.5 20.5 18.5 23.5 17.5 20.5 14.5 19.5 17.5 18.5Z"/>
                <path d="M5 14 5.5 16 7.5 16.5 5.5 17 5 19 4.5 17 2.5 16.5 4.5 16Z"/>
              </svg>
            )}
            {s.icon === 'ti-confetti' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="40" height="40" aria-hidden="true">
                <path d="M4 5h2"/>
                <path d="M5 4v2"/>
                <path d="m11.5 4 -.5 2"/>
                <path d="M18 5h2"/>
                <path d="M19 4v2"/>
                <path d="m15 9 -1 1"/>
                <path d="m18 13 2 -.5"/>
                <path d="M18 19h2"/>
                <path d="M19 18v2"/>
                <path d="M14 16.52l-6.52 -6.52l-4.39 9.58a1 1 0 0 0 1.33 1.33z"/>
              </svg>
            )}
            {s.icon === 'ti-puzzle' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="40" height="40" aria-hidden="true">
                <path d="M4 7h3a1 1 0 0 0 1 -1v-1a2 2 0 0 1 4 0v1a1 1 0 0 0 1 1h3a1 1 0 0 1 1 1v3a1 1 0 0 0 1 1h1a2 2 0 0 1 0 4h-1a1 1 0 0 0 -1 1v3a1 1 0 0 1 -1 1h-3a1 1 0 0 1 -1 -1v-1a2 2 0 0 0 -4 0v1a1 1 0 0 1 -1 1h-3a1 1 0 0 1 -1 -1v-3a1 1 0 0 1 1 -1h1a2 2 0 0 0 0 -4h-1a1 1 0 0 1 -1 -1v-3a1 1 0 0 1 1 -1"/>
              </svg>
            )}
            {s.icon === 'ti-speakerphone' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="40" height="40" aria-hidden="true">
                <path d="M18 8a3 3 0 0 1 0 6"/>
                <path d="M10 8v11a1 1 0 0 1 -1 1h-1a1 1 0 0 1 -1 -1v-5"/>
                <path d="M12 8l4.5 -3.75a.9 .9 0 0 1 1.5 .7v12.1a.9 .9 0 0 1 -1.5 .7l-4.5 -3.75h-8a1 1 0 0 1 -1 -1v-4a1 1 0 0 1 1 -1z"/>
              </svg>
            )}
            {s.icon === 'ti-message-2-heart' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="40" height="40" aria-hidden="true">
                <path d="M11.99 19.83l-3.99 2.17v-4h-3a3 3 0 0 1 -3 -3v-8a3 3 0 0 1 3 -3h12a3 3 0 0 1 3 3v3.5"/>
                <path d="M18 22l3.35 -3.28a2.14 2.14 0 0 0 0 -3.07a2.24 2.24 0 0 0 -3.13 0l-.22 .22l-.22 -.22a2.24 2.24 0 0 0 -3.13 0a2.14 2.14 0 0 0 0 3.07z"/>
              </svg>
            )}
            {s.icon === 'ti-envelope' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="40" height="40" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2"/>
                <path d="m3 7 9 7 9-7"/>
              </svg>
            )}
            {s.icon === 'ti-writing' && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="40" height="40" aria-hidden="true">
                <path d="M20 17v-12c0 -1.12 -.88 -2 -2 -2s-2 .88 -2 2v12l2 2z"/>
                <path d="M16 7h4"/>
                <path d="M18 19h-13a2 2 0 0 1 -2 -2v-10a2 2 0 0 1 2 -2h4"/>
              </svg>
            )}
          </div>

          <h2 class="mt-4 text-lg font-bold tracking-tight text-neutral-900">{s.name}</h2>
          <p class="mt-2 text-sm italic leading-relaxed text-neutral-600">{s.tagline}</p>
        </div>
      </article>
    ))}
  </section>

  <div class="mt-16 text-center">
    <p class="mb-5 text-xl font-semibold text-neutral-900">Ready to dream big?</p>
    <a
      href="/contact"
      class="inline-flex items-center justify-center rounded-full px-8 py-3.5 text-base font-bold text-white shadow-md transition-transform hover:scale-[1.02] hover:shadow-lg active:scale-[0.99]"
      style={`background-color: ${TEAL};`}
    >
      Let's talk &rarr;
    </a>
  </div>
</Layout>

<style>
  .dream-big-banner {
    background-image: url('/dream-big-sky.jpg');
    background-size: cover;
    background-position: center;
    border-radius: 12px;
    padding: 56px 24px;
    text-align: center;
  }
  .dream-big-heading {
    font-family: 'Lilita One', cursive;
    color: #ffffff;
    -webkit-text-stroke: 12px #E8B84B;
    paint-order: stroke fill;
    /* Scales down on mobile so the heading fits without horizontal overflow. */
    font-size: clamp(2rem, 8vw, 100px);
    white-space: nowrap;
    line-height: 1;
    margin: 0;
  }
  .dream-big-subtitle {
    color: #000000;
    font-size: 17px;
    font-style: italic;
    margin: 22px auto 0;
    max-width: 540px;
    line-height: 1.45;
  }
</style>
