---
// Persistent corner mascot — bottom-right of every page that doesn't pass noMascot.
// The speech bubble is ALWAYS visible (Clippy-style) and starts on "Here to help!".
// Clicking Ollie cycles through a short list of friendly responses, then loops.
---

<div class="corner-ollie">
  <div class="corner-ollie-bubble" role="status" aria-live="polite">Here to help!</div>
  <button
    type="button"
    class="corner-ollie-trigger"
    aria-label="Tap Ollie for a tip"
  >
    <img
      class="corner-ollie-img"
      src="/ollie-full-body.png"
      alt="Ollie the mascot"
      draggable="false"
    />
  </button>
</div>

<style>
  .corner-ollie {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    z-index: 999;
    pointer-events: none; /* container itself is click-through; only inner widgets catch clicks */
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
  }
  .corner-ollie-trigger {
    all: unset;
    display: block;
    cursor: pointer;
    pointer-events: auto;
    border-radius: 8px;
  }
  .corner-ollie-trigger:focus-visible {
    outline: 2px solid #05d7d1;
    outline-offset: 4px;
  }
  .corner-ollie-img {
    display: block;
    width: auto;
    height: 144px;
    user-select: none;
    -webkit-user-drag: none;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.2));
    transform-origin: bottom center;
    animation: corner-ollie-bob 3.6s ease-in-out infinite;
  }
  @keyframes corner-ollie-bob {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-4px) rotate(-1.2deg); }
  }

  /* Always-visible Clippy-style bubble — sits above Ollie and stays put. */
  .corner-ollie-bubble {
    position: relative;
    background: #ffffff;
    color: #1f1f1f;
    border: 2px solid #05d7d1;
    border-radius: 14px;
    padding: 0.55rem 0.95rem;
    font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.35;
    max-width: 260px;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
    pointer-events: none;
    /* Animate text changes gently so cycling feels alive */
    transition: opacity 0.18s ease-out;
  }
  .corner-ollie-bubble.is-swapping {
    opacity: 0;
  }
  /* Little tail at the bubble's bottom-right pointing toward Ollie's head */
  .corner-ollie-bubble::after {
    content: '';
    position: absolute;
    right: 24px;
    bottom: -10px;
    width: 0;
    height: 0;
    border: 10px solid transparent;
    border-top-color: #ffffff;
    /* fake the border match by stacking a second triangle behind it */
    filter: drop-shadow(0 1px 0 #05d7d1) drop-shadow(1px 0 0 #05d7d1) drop-shadow(-1px 0 0 #05d7d1);
  }

  @media (prefers-reduced-motion: reduce) {
    .corner-ollie-img { animation: none; }
    .corner-ollie-bubble { transition: none; }
  }
</style>

<script>
  (function () {
    const root = document.querySelector('.corner-ollie') as HTMLElement | null;
    const trigger = root?.querySelector('.corner-ollie-trigger') as HTMLButtonElement | null;
    const bubble = root?.querySelector('.corner-ollie-bubble') as HTMLElement | null;
    if (!root || !trigger || !bubble) return;

    // Short list of friendly Ollie tips. Index 0 is the default "Here to help!" line
    // that's rendered server-side; clicking advances and loops back to it.
    const messages = [
      'Here to help!',
      "Hi! I'm Ollie — Theia's mascot.",
      "Pricing's up top — give it a click!",
      "Got a project? Tap 'Contact'.",
      "Theia builds sites that don't look like everyone else's.",
    ];
    let index = 0;

    trigger.addEventListener('click', () => {
      index = (index + 1) % messages.length;
      const next = messages[index];

      // Brief fade-out, swap text, fade back in — keeps cycling from feeling jarring
      bubble.classList.add('is-swapping');
      window.setTimeout(() => {
        bubble.textContent = next;
        bubble.classList.remove('is-swapping');
      }, 180);
    });
  })();
</script>
