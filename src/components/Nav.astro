---
const { pathname } = Astro.url;

const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
] as const;

const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname === `${href}/`;
---

<nav class="border-b border-neutral-200">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-4 py-4">
    <a href="/" class="font-semibold tracking-tight">sociallyawkward.me</a>
    <ul class="flex gap-4 text-sm">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'transition-colors hover:text-neutral-900',
                isActive(link.href) ? 'text-neutral-900 font-medium' : 'text-neutral-500',
              ]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>
