---
// Phase A + B + C + D: Light switch → curtains open → bg white → PRESENTS zooms with Ollie hanging
//                      like a pendulum → PRESENTS pops with a glitter burst → Ollie drops to corner
//                      → persistent corner mascot appears with a chat bubble that fades after 4s.
// Only asset in use: /ollie-full-body.png
---

<div id="ollie-intro-root" data-state="checking">
  {/* ---------- Light switch (first visit only) ---------- */}
  <div class="oi-switch-screen" data-oi-screen="switch" hidden>
    <div class="oi-switch-plate">
      <span class="oi-switch-label oi-label-on">ON</span>
      <div class="oi-switch" data-pos="mid">
        <span class="oi-switch-track"></span>
        <span class="oi-switch-knob"></span>
        <button class="oi-switch-zone oi-zone-up" data-oi-action="up" aria-label="Flip switch ON — watch the intro" type="button"></button>
        <button class="oi-switch-zone oi-zone-down" data-oi-action="down" aria-label="Flip switch OFF — skip the intro" type="button"></button>
      </div>
      <span class="oi-switch-label oi-label-off">OFF</span>
    </div>
  </div>

  {/* ---------- Stage (curtains + bg transition) ---------- */}
  <div class="oi-stage" data-oi-screen="stage" hidden>
    <button class="oi-skip-btn" data-oi-action="skip" type="button">Skip Intro</button>

    <div class="oi-curtain oi-panel-left">
      <div class="oi-curtain-fabric">
        <span class="oi-curtain-text" aria-hidden="true">Socially Awkward Media</span>
      </div>
    </div>
    <div class="oi-curtain oi-panel-right">
      <div class="oi-curtain-fabric">
        <span class="oi-curtain-text oi-curtain-text-right" aria-hidden="true">Socially Awkward Media</span>
      </div>
    </div>

    {/* PRESENTS text — zooms in, then pops */}
    <div class="oi-presents" data-phase="hidden" aria-hidden="true">PRESENTS</div>

    {/* Ollie — hangs below PRESENTS swinging as a pendulum, then drops to corner */}
    <div class="oi-ollie-pos" data-phase="hidden">
      <div class="oi-ollie-swing">
        <img class="oi-ollie-img" src="/ollie-full-body.png" alt="" draggable="false" />
      </div>
    </div>

    {/* Glitter canvas — particle burst fires at the moment PRESENTS pops */}
    <canvas class="oi-glitter" aria-hidden="true"></canvas>
  </div>

  {/* ---------- Persistent corner mascot + Clippy-style FAQ ---------- */}
  <div class="oi-corner" data-oi-screen="corner" data-ollie="idle" hidden>
    {/* One-time greeting bubble shown right after the intro completes (above Ollie) */}
    <div class="oi-corner-bubble" hidden>I'll just be over here if you need me, friend.</div>

    {/* Persistent "Here to help!" bubble — classic Clippy thought-bubble (left of Ollie),
        hidden while the chat panel is open. The bubble + 3-dot chain are one element so they
        show and hide together. */}
    <div class="oi-help-bubble" data-state="hidden" aria-hidden="true">
      Here to help!
      <span class="oi-help-dot oi-help-dot-1"></span>
      <span class="oi-help-dot oi-help-dot-2"></span>
      <span class="oi-help-dot oi-help-dot-3"></span>
    </div>

    {/* Chat panel — slides up above Ollie when clicked */}
    <div class="oi-chat-panel" data-state="closed" role="dialog" aria-label="Help panel">
      <div class="oi-chat-bar">
        <button class="oi-chat-close" type="button" aria-label="Close help panel">×</button>
      </div>
      <div class="oi-chat-content">
        <div class="oi-chat-questions">
          <button class="oi-q" type="button" data-q="do">What do you do?</button>
          <button class="oi-q" type="button" data-q="start">How do I get started?</button>
          <button class="oi-q" type="button" data-q="who">Who are you, little guy?</button>
          <button class="oi-q" type="button" data-q="cost">How much does it cost?</button>
        </div>
        <div class="oi-chat-answer" hidden></div>
      </div>
    </div>

    <img class="oi-corner-img" src="/ollie-full-body.png" alt="Ollie the mascot" draggable="false" />
  </div>
</div>

<style>
  /* ============================================================
     Light switch screen
     ============================================================ */
  .oi-switch-screen {
    position: fixed; inset: 0; z-index: 10001;
    background: #000; color: #f4f4f4;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 1.4rem;
    font-family: ui-serif, Georgia, serif;
  }

  .oi-switch-plate {
    position: relative;
    width: 112px;
    padding: 16px 0;
    background: linear-gradient(180deg, #f3eee2, #cdc4ad);
    border-radius: 10px;
    border: 1px solid #8b7d54;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.65), inset 0 0 0 2px rgba(255, 255, 255, 0.3);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 10px;
  }
  .oi-switch-label {
    font-family: ui-serif, Georgia, serif;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: #5a4623;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.5);
    user-select: none;
  }
  .oi-switch {
    position: relative;
    width: 38px; height: 118px;
  }
  .oi-switch-track {
    position: absolute; inset: 0;
    background: #181818;
    border-radius: 5px;
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.8), inset 0 2px 0 rgba(0, 0, 0, 0.9);
  }
  .oi-switch-knob {
    position: absolute; left: 4px; right: 4px;
    height: 54px;
    background: linear-gradient(180deg, #f5f1e6, #b3a98a);
    border-radius: 4px;
    box-shadow: 0 3px 7px rgba(0, 0, 0, 0.7), inset 0 1px 0 rgba(255, 255, 255, 0.55);
    transition: top 0.5s cubic-bezier(.5, 1.6, .4, 1), bottom 0.5s cubic-bezier(.5, 1.6, .4, 1);
    top: calc(50% - 27px);
  }
  .oi-switch[data-pos="up"] .oi-switch-knob { top: 4px; bottom: auto; }
  .oi-switch[data-pos="down"] .oi-switch-knob { top: auto; bottom: 4px; }

  /* Two transparent click zones (top half = ON, bottom half = OFF) sit on top of the knob */
  .oi-switch-zone {
    all: unset;
    position: absolute;
    left: -14px; right: -14px;
    cursor: pointer;
    background: transparent;
    z-index: 2;
  }
  .oi-zone-up   { top: 0;    height: 50%; }
  .oi-zone-down { bottom: 0; height: 50%; }
  .oi-switch-zone:focus-visible { outline: 2px solid #f1d97a; outline-offset: 2px; border-radius: 4px; }

  /* ============================================================
     Stage
     ============================================================ */
  .oi-stage {
    position: fixed; inset: 0; z-index: 10000;
    background: #000;
    overflow: hidden;
    transition: background 2s ease-in;
  }
  .oi-stage[data-lit="true"] {
    background: radial-gradient(ellipse at 50% 28%, #4a3214 0%, #1a0e05 55%, #000 100%);
    transition: background 2s ease-in;
  }
  /* Background brightens to white as curtains slide open */
  .oi-stage[data-curtains="open"] {
    background: #fff;
    transition: background 2.5s ease-in-out;
  }

  .oi-skip-btn {
    position: absolute; top: 1rem; right: 1rem;
    z-index: 20;
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    font-size: 0.8rem;
    cursor: pointer;
    backdrop-filter: blur(4px);
    font-family: inherit;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .oi-skip-btn:hover { background: rgba(255, 255, 255, 0.28); }
  /* When the stage is white, flip the button to dark text for contrast */
  .oi-stage[data-curtains="open"] .oi-skip-btn {
    background: rgba(0, 0, 0, 0.08);
    color: #333;
    border-color: rgba(0, 0, 0, 0.25);
  }
  .oi-stage[data-curtains="open"] .oi-skip-btn:hover { background: rgba(0, 0, 0, 0.16); }

  /* curtains */
  .oi-curtain {
    position: absolute; top: 0; bottom: 0;
    width: 50vw;
    z-index: 4;
    transition: transform 2.5s cubic-bezier(.7, 0, .3, 1);
    will-change: transform;
  }
  .oi-panel-left { left: 0; transform: translateX(0); }
  .oi-panel-right { right: 0; transform: translateX(0); }

  .oi-curtain-fabric {
    position: absolute; inset: 0;
    background:
      repeating-linear-gradient(90deg,
        rgba(0, 0, 0, 0.28) 0 10px,
        rgba(255, 255, 255, 0.06) 10px 22px,
        rgba(0, 0, 0, 0.14) 22px 38px),
      linear-gradient(180deg, #005a5a 0%, #008080 25%, #00a0a0 65%, #006464 100%);
    box-shadow: inset 0 0 80px rgba(0, 0, 0, 0.45);
    transform-origin: top center;
    animation: oi-sway 5.5s ease-in-out infinite;
    overflow: hidden;
  }
  .oi-panel-right .oi-curtain-fabric { animation-delay: -2.7s; }

  @keyframes oi-sway {
    0%, 100% { transform: skewX(0deg) scaleY(1); }
    50%      { transform: skewX(0.45deg) scaleY(1.003); }
  }

  .oi-curtain-text {
    position: absolute;
    top: 38%;
    left: 0;
    width: 100vw;
    text-align: center;
    color: #f1d97a;
    font-weight: 800;
    font-size: clamp(2rem, 6.2vw, 5rem);
    letter-spacing: 0.08em;
    text-shadow: 0 4px 14px rgba(0, 0, 0, 0.75), 0 0 30px rgba(241, 217, 122, 0.25);
    font-family: ui-serif, Georgia, serif;
    pointer-events: none;
    white-space: nowrap;
  }
  .oi-curtain-text-right { left: auto; right: 0; }

  /* Curtain states */
  .oi-stage[data-curtains="open"] .oi-panel-left  { transform: translateX(-100%); }
  .oi-stage[data-curtains="open"] .oi-panel-right { transform: translateX(100%); }

  /* ============================================================
     PRESENTS marquee text
     ============================================================ */
  .oi-presents {
    position: fixed;
    top: 26%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.05);
    opacity: 0;
    z-index: 8;
    color: #1f1f1f;
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 12vw, 9rem);
    letter-spacing: 0.14em;
    line-height: 1;
    text-shadow:
      0 0 24px rgba(0, 128, 128, 0.18),
      0 6px 20px rgba(0, 0, 0, 0.18);
    pointer-events: none;
    user-select: none;
    will-change: transform, opacity;
  }
  .oi-presents[data-phase="zoom"] {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    transition:
      opacity 0.5s ease-out,
      transform 1.2s cubic-bezier(.18, 1.2, .5, 1);
  }
  /* Balloon pop: brief blow-out + fade */
  .oi-presents[data-phase="pop"] {
    opacity: 0;
    transform: translate(-50%, -50%) scale(1.55);
    transition:
      opacity 0.22s ease-out,
      transform 0.25s cubic-bezier(.4, 0, .7, .2);
  }

  /* ============================================================
     Ollie — hangs below PRESENTS, swings, then drops to corner
     ============================================================ */
  /* Outer wrapper handles position (top/left/width/height). Inner .swing handles pendulum rotation,
     so the two transforms don't fight. */
  .oi-ollie-pos {
    position: fixed;
    top: 38%;
    left: 50%;
    width: clamp(110px, 18vw, 200px);
    height: clamp(160px, 28vh, 280px);
    transform: translateX(-50%);
    opacity: 0;
    z-index: 7;
    pointer-events: none;
    transition: opacity 0.4s ease;
    will-change: transform, top, left, width, height;
  }
  .oi-ollie-pos[data-phase="hanging"] {
    opacity: 1;
  }
  .oi-ollie-pos[data-phase="drop"] {
    opacity: 1;
    top: calc(100vh - 1rem - 80px);
    left: calc(100vw - 1rem);
    width: 56px;
    height: 80px;
    transform: translateX(-100%);
    /* Gravity-flavored easing: starts slow, accelerates downward; X eases out gently */
    transition:
      top 1.4s cubic-bezier(.55, 0, .85, .25),
      left 1.4s cubic-bezier(.25, .55, .55, 1),
      width 1.4s cubic-bezier(.5, 0, .7, .5),
      height 1.4s cubic-bezier(.5, 0, .7, .5),
      transform 1.4s cubic-bezier(.4, 0, .6, 1);
  }

  .oi-ollie-swing {
    width: 100%;
    height: 100%;
    transform-origin: top center;
    transform: rotate(0deg);
  }
  /* Pendulum sway when hanging */
  .oi-ollie-pos[data-phase="hanging"] .oi-ollie-swing {
    animation: oi-pendulum 2.6s ease-in-out infinite;
  }
  /* Stop pendulum cleanly when dropping */
  .oi-ollie-pos[data-phase="drop"] .oi-ollie-swing {
    animation: none;
    transform: rotate(0deg);
    transition: transform 0.25s ease-out;
  }

  @keyframes oi-pendulum {
    0%, 100% { transform: rotate(-8deg); }
    50%      { transform: rotate(8deg); }
  }

  .oi-ollie-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    user-select: none;
    -webkit-user-drag: none;
  }

  /* ============================================================
     Glitter canvas — full-screen particle burst at the pop moment
     ============================================================ */
  .oi-glitter {
    position: absolute;
    inset: 0;
    z-index: 9;
    pointer-events: none;
  }

  /* ============================================================
     Persistent corner mascot + Clippy-style FAQ
     ============================================================ */
  .oi-corner {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    z-index: 999;
    pointer-events: none; /* container transparent — only inner widgets catch clicks */
  }
  .oi-corner-img {
    display: block;
    width: auto;
    height: 144px;
    cursor: pointer;
    user-select: none;
    -webkit-user-drag: none;
    pointer-events: auto;
    animation: oi-bob 3.6s ease-in-out infinite;
    transform-origin: bottom center;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.2));
  }
  @keyframes oi-bob {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-4px) rotate(-1.2deg); }
  }

  /* One-time greeting bubble (above Ollie) */
  .oi-corner-bubble {
    position: absolute;
    bottom: calc(100% + 8px);
    right: 0;
    background: #fff;
    color: #1f1f1f;
    padding: 0.55rem 0.85rem;
    border-radius: 14px;
    font-size: 0.85rem;
    max-width: 240px;
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.18);
    border: 1px solid rgba(0, 0, 0, 0.06);
    line-height: 1.3;
    pointer-events: auto;
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .oi-corner-bubble::after {
    content: '';
    position: absolute;
    right: 16px;
    bottom: -8px;
    width: 0;
    height: 0;
    border: 8px solid transparent;
    border-top-color: #fff;
    filter: drop-shadow(0 1px 0 rgba(0, 0, 0, 0.06));
  }
  .oi-corner-bubble[data-fade="out"] {
    opacity: 0;
    transform: translateY(6px);
  }

  /* Persistent "Here to help!" bubble — classic Clippy thought-bubble look:
     white fill, teal border, no triangle tail. Sits ABOVE Ollie, horizontally centered on him,
     with a descending dot-chain (3 circles) trailing from the bubble's bottom down to his head. */
  .oi-help-bubble {
    position: absolute;
    bottom: calc(100% + 42px); /* 42px gap above Ollie leaves room for the dot chain (~33px) */
    right: 0; /* anchor bubble right edge to Ollie's right edge so it doesn't overflow the viewport */
    left: auto;
    background: #ffffff;
    color: #1f1f1f;
    border: 2px solid #05d7d1;
    padding: 0.5rem 0.95rem;
    border-radius: 14px;
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.12);
    pointer-events: auto;
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .oi-help-bubble[data-state="visible"] { opacity: 1; }

  /* Thought-bubble dot chain — three filled circles descending below the bubble */
  .oi-help-dot {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    background: #ffffff;
    border: 1.5px solid #05d7d1;
    border-radius: 50%;
    box-sizing: border-box;
    pointer-events: none;
  }
  .oi-help-dot-1 { /* largest, closest to bubble */
    width: 10px;
    height: 10px;
    top: calc(100% + 4px);
  }
  .oi-help-dot-2 { /* middle */
    width: 6px;
    height: 6px;
    top: calc(100% + 19px);
  }
  .oi-help-dot-3 { /* smallest, furthest from bubble */
    width: 3px;
    height: 3px;
    top: calc(100% + 30px);
  }

  /* Chat panel — slides up above Ollie when clicked */
  .oi-chat-panel {
    position: absolute;
    bottom: calc(100% + 12px);
    right: 0;
    width: 260px;
    background: #ffffff;
    border: 2px solid #05d7d1;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.2);
    pointer-events: none;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .oi-chat-panel[data-state="open"] {
    pointer-events: auto;
    opacity: 1;
    transform: translateY(0);
  }

  .oi-chat-bar {
    height: 36px;
    background: #E8B84B;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 6px;
  }
  .oi-chat-close {
    all: unset;
    font-family: inherit;
    cursor: pointer;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: bold;
    color: #1a1208;
    line-height: 1;
    transition: background 0.2s ease;
  }
  .oi-chat-close:hover { background: rgba(0, 0, 0, 0.14); }
  .oi-chat-close:focus-visible { outline: 2px solid #05d7d1; outline-offset: 1px; }

  .oi-chat-content {
    padding: 12px;
  }
  .oi-chat-questions {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .oi-q {
    all: unset;
    font-family: inherit;
    cursor: pointer;
    display: block;
    padding: 9px 12px;
    background: #05d7d1;
    color: #ffffff;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.25;
    text-align: left;
    transition: background 0.15s ease, transform 0.1s ease;
  }
  .oi-q:hover { background: #04bcb6; }
  .oi-q:active { transform: scale(0.985); }
  .oi-q:focus-visible { outline: 2px solid #E8B84B; outline-offset: 2px; }

  .oi-chat-answer {
    margin-top: 12px;
    padding: 10px 12px;
    background: #f6f6f6;
    border-left: 3px solid #05d7d1;
    border-radius: 6px;
    font-size: 0.85rem;
    line-height: 1.4;
    color: #1f1f1f;
    white-space: pre-line; /* render \n in the ANSWERS strings as visual line breaks */
  }

  @media (prefers-reduced-motion: reduce) {
    .oi-curtain-fabric,
    .oi-ollie-swing,
    .oi-corner-img { animation: none !important; }
    .oi-curtain,
    .oi-stage,
    .oi-presents,
    .oi-ollie-pos,
    .oi-corner-bubble { transition-duration: 0.4s !important; }
  }
</style>

<script>
  (function () {
    const LS_KEY = 'ollie-intro-seen';
    const SS_KEY = 'ollie-intro-played-session';

    const root = document.getElementById('ollie-intro-root');
    if (!root || root.dataset.state !== 'checking') return;

    const q = (sel: string) => root.querySelector(sel) as HTMLElement | null;

    const screens = {
      switch: q('[data-oi-screen="switch"]'),
      stage: q('[data-oi-screen="stage"]'),
      corner: q('[data-oi-screen="corner"]'),
    };
    const elSwitch = q('.oi-switch') as HTMLElement | null;
    const elZoneUp = q('[data-oi-action="up"]') as HTMLButtonElement | null;
    const elZoneDown = q('[data-oi-action="down"]') as HTMLButtonElement | null;
    const elSkipBtn = q('.oi-skip-btn') as HTMLButtonElement | null;
    const elStage = q('.oi-stage');
    const elPresents = q('.oi-presents');
    const elOlliePos = q('.oi-ollie-pos');
    const elGlitter = q('.oi-glitter') as HTMLCanvasElement | null;
    const elCorner = q('.oi-corner');
    const elBubble = q('.oi-corner-bubble');
    const elCornerImg = q('.oi-corner-img') as HTMLImageElement | null;
    const elHelpBubble = q('.oi-help-bubble');
    const elChatPanel = q('.oi-chat-panel');
    const elChatClose = q('.oi-chat-close') as HTMLButtonElement | null;
    const elChatAnswer = q('.oi-chat-answer');
    const qButtons = Array.from(root.querySelectorAll('.oi-q')) as HTMLButtonElement[];

    // FAQ answers keyed by data-q on each question button.
    // Newlines render as line breaks via `white-space: pre-line` on .oi-chat-answer.
    const ANSWERS: Record<string, string> = {
      'who': `It looks like you're trying to find out who I am.
I'm Ollie. I hold down the corner so Theia doesn't have to. I'm here to help.`,
      'do': `Socially Awkward Media does two things really well:
🎨 Graphic Design — logos, branding, the works
🌐 Web Design — sites that actually function like sites
Basically? We make your brand look as good as the work you do.`,
      'cost': `Oh, you want to talk money. Bold.
Every project's a little different, so Theia handles that conversation personally.
Head to the contact page — she doesn't bite.
(I might. Just kidding. I don't have teeth.)`,
      'start': `Ooh, a new friend! 🎉 Getting started is the easy part — just head to the contact page and tell us what your goals are for your website. What's its priority purpose, are there any features you want it to have specifically, and do you need a shopping cart. Theia takes it from there. You already did your hardest part just by knocking on the door.`,
    };

    function setHelpBubbleVisible(visible: boolean) {
      if (!elHelpBubble) return;
      if (visible) {
        (elHelpBubble as HTMLElement).dataset.state = 'visible';
      } else {
        (elHelpBubble as HTMLElement).dataset.state = 'hidden';
      }
    }

    function toggleChatPanel() {
      if (!elChatPanel) return;
      const panel = elChatPanel as HTMLElement;
      const isOpen = panel.dataset.state === 'open';
      if (isOpen) {
        panel.dataset.state = 'closed';
        setHelpBubbleVisible(true);
      } else {
        panel.dataset.state = 'open';
        setHelpBubbleVisible(false);
      }
    }

    // Click handlers — bound once on initial render (works whether the user arrives via
    // intro completion, skip, or as a returning visitor; the corner mascot DOM is always present)
    elCornerImg?.addEventListener('click', toggleChatPanel);
    elChatClose?.addEventListener('click', toggleChatPanel);
    qButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.q;
        if (!key || !ANSWERS[key] || !elChatAnswer) return;
        elChatAnswer.textContent = ANSWERS[key];
        elChatAnswer.removeAttribute('hidden');
      });
    });

    const show = (el: Element | null) => el && el.removeAttribute('hidden');
    const hide = (el: Element | null) => el && el.setAttribute('hidden', '');

    const readLS = (k: string) => { try { return localStorage.getItem(k); } catch { return null; } };
    const writeLS = (k: string, v: string) => { try { localStorage.setItem(k, v); } catch {} };
    const writeSS = (k: string, v: string) => { try { sessionStorage.setItem(k, v); } catch {} };

    const sleep = (ms: number) => new Promise<void>((r) => setTimeout(r, ms));

    // Strip switch + stage from the DOM (keep the corner mascot)
    function removeIntroDom() {
      screens.switch?.remove();
      screens.stage?.remove();
    }

    // Reveal the persistent corner Ollie and clean up the intro DOM.
    // Returning/skip paths get the help bubble immediately; intro-completion path waits for
    // the greeting bubble to fade first (see startIntro()).
    function settleCornerOnly(opts: { showHelp?: boolean } = { showHelp: true }) {
      hide(screens.switch);
      hide(screens.stage);
      show(elCorner);
      removeIntroDom();
      if (opts.showHelp) setHelpBubbleVisible(true);
      root.dataset.state = 'corner';
    }

    // ---- Routing ----
    const seen = readLS(LS_KEY);

    if (!seen) {
      // First visit ever — show the light switch
      show(screens.switch);
      root.dataset.state = 'switch';
      elZoneUp?.addEventListener('click', () => choose('intro'));
      elZoneDown?.addEventListener('click', () => choose('skip'));
    } else {
      // Returning visit (any path) — just the persistent corner mascot, no intro replay
      settleCornerOnly();
    }

    function choose(choice: 'intro' | 'skip') {
      writeLS(LS_KEY, choice);
      writeSS(SS_KEY, '1');
      if (!elSwitch) return;

      if (choice === 'intro') {
        elSwitch.dataset.pos = 'up';
        setTimeout(() => startIntro(), 480);
      } else {
        elSwitch.dataset.pos = 'down';
        setTimeout(() => settleCornerOnly(), 480);
      }
    }

    let introState: 'idle' | 'running' | 'done' = 'idle';

    async function startIntro() {
      if (introState !== 'idle') return;
      introState = 'running';
      hide(screens.switch);
      show(screens.stage);
      root.dataset.state = 'intro';

      elSkipBtn?.addEventListener('click', () => { introState = 'done'; settleCornerOnly(); }, { once: true });

      // 1. Lights illuminate (2s)
      await sleep(150);
      if (elStage) (elStage as HTMLElement).dataset.lit = 'true';
      await sleep(2000);
      if (introState !== 'running') return;

      // 2. Curtains slide fully open + background transitions from black to white (2.5s)
      if (elStage) (elStage as HTMLElement).dataset.curtains = 'open';
      await sleep(2500);
      if (introState !== 'running') return;

      // 3. Beat, then PRESENTS zooms in (1.2s) and Ollie hangs from it
      await sleep(400);
      if (elPresents) (elPresents as HTMLElement).dataset.phase = 'zoom';
      if (elOlliePos) (elOlliePos as HTMLElement).dataset.phase = 'hanging';
      await sleep(1300);
      if (introState !== 'running') return;

      // 4. Hold while Ollie swings like a pendulum
      await sleep(2200);
      if (introState !== 'running') return;

      // 5. PRESENTS pops + glitter burst; Ollie simultaneously drops to the bottom-right corner
      if (elPresents) (elPresents as HTMLElement).dataset.phase = 'pop';
      if (elOlliePos) (elOlliePos as HTMLElement).dataset.phase = 'drop';
      runGlitter();
      await sleep(1500);
      if (introState !== 'running') return;

      // 6. Hand off from the stage Ollie to the persistent corner mascot.
      //    Help bubble stays hidden during the one-time greeting — we'll reveal it once that fades.
      settleCornerOnly({ showHelp: false });
      await sleep(80);

      // 7. One-time greeting chat bubble pops in, holds for ~4s, then fades out
      show(elBubble);
      await sleep(4000);
      if (elBubble) (elBubble as HTMLElement).dataset.fade = 'out';
      await sleep(750);
      elBubble?.remove();

      // 8. Persistent "Here to help!" bubble appears (resting state of the Clippy widget)
      setHelpBubbleVisible(true);

      introState = 'done';
    }

    // ------------------------------------------------------------
    // Glitter explosion — canvas particle burst from where PRESENTS sat.
    // Colors: gold, brand teal, white, pink, silver. Gravity + spin + 1.5s fade.
    // ------------------------------------------------------------
    function runGlitter() {
      if (!elGlitter) return;
      const ctx = elGlitter.getContext('2d');
      if (!ctx) return;

      const dpr = window.devicePixelRatio || 1;
      const w = window.innerWidth;
      const h = window.innerHeight;
      elGlitter.width = w * dpr;
      elGlitter.height = h * dpr;
      elGlitter.style.width = w + 'px';
      elGlitter.style.height = h + 'px';
      ctx.scale(dpr, dpr);

      const colors = ['#d4af37', '#05d7d1', '#ffffff', '#ff9ec7', '#c0c0c0'];
      // Origin matches PRESENTS' visual center (top: 26%)
      const cx = w / 2;
      const cy = h * 0.26;

      type P = {
        x: number; y: number;
        vx: number; vy: number;
        size: number; color: string;
        rot: number; spin: number;
      };
      const particles: P[] = [];
      const count = 240;
      for (let i = 0; i < count; i++) {
        const angle = Math.random() * Math.PI * 2;
        const speed = 5 + Math.random() * 11;
        particles.push({
          x: cx, y: cy,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed - 3, // slight upward bias
          size: 2 + Math.random() * 5,
          color: colors[(Math.random() * colors.length) | 0],
          rot: Math.random() * Math.PI,
          spin: (Math.random() - 0.5) * 0.45,
        });
      }

      const start = performance.now();
      const duration = 1500;
      const c = ctx; // narrow type for inner closure
      function frame(now: number) {
        const t = Math.min(1, (now - start) / duration);
        c.clearRect(0, 0, w, h);
        for (const p of particles) {
          p.vy += 0.28; // gravity
          p.vx *= 0.985; // air resistance
          p.x += p.vx;
          p.y += p.vy;
          p.rot += p.spin;
          c.save();
          c.globalAlpha = Math.max(0, 1 - t);
          c.translate(p.x, p.y);
          c.rotate(p.rot);
          c.fillStyle = p.color;
          c.fillRect(-p.size / 2, -p.size / 2, p.size, p.size * 1.7);
          c.restore();
        }
        if (t < 1) requestAnimationFrame(frame);
        else elGlitter?.remove();
      }
      requestAnimationFrame(frame);
    }
  })();
</script>
